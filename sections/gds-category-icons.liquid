<section class="gds-categories">
  <div class="gds-container">

    <div class="gds-sec-head">
      <h2>{{ section.settings.title }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p>{{ section.settings.subtitle }}</p>
      {%- endif -%}
      <div class="gds-underline-bar"></div>
    </div>

    <div class="gds-cat-grid">
      {%- for block in section.blocks -%}
        <a
          href="{{ routes.collections_url }}/{{ block.settings.collection_handle }}"
          class="gds-cat-item"
          {{ block.shopify_attributes }}
          aria-label="{{ block.settings.label }}"
        >
          <div class="gds-cat-circle">
            {%- assign cat_collection = collections[block.settings.collection_handle] -%}
            {%- if cat_collection.image -%}
              {{ cat_collection.image
                 | image_url: width: 200
                 | image_tag:
                     width: 80,
                     height: 80,
                     class: "gds-cat-img",
                     alt: block.settings.label }}
            {%- else -%}
              {%- case block.settings.icon_type -%}

                {%- when 'perro' -%}
                  <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2"
                       stroke-linecap="round" stroke-linejoin="round"
                       aria-hidden="true" focusable="false">
                    <path d="M44 8c2 0 8 2 8 8v4l4 4v8l-4 2v6c0 4-2 6-6 6H18c-4 0-6-2-6-6v-6l-4-2v-8l4-4V16c0-6 6-8 8-8"/>
                    <circle cx="24" cy="26" r="2" fill="currentColor" stroke="none"/>
                    <circle cx="40" cy="26" r="2" fill="currentColor" stroke="none"/>
                    <path d="M28 34c0 0 2 3 8 0"/>
                    <path d="M18 8 L12 2 M46 8 L52 2"/>
                  </svg>

                {%- when 'gato' -%}
                  <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2"
                       stroke-linecap="round" stroke-linejoin="round"
                       aria-hidden="true" focusable="false">
                    <path d="M16 8 L8 2 L8 20 C8 20 8 14 16 14"/>
                    <path d="M48 8 L56 2 L56 20 C56 20 56 14 48 14"/>
                    <path d="M16 14 C16 14 10 18 10 30 C10 42 20 50 32 50 C44 50 54 42 54 30 C54 18 48 14 48 14"/>
                    <circle cx="24" cy="30" r="2" fill="currentColor" stroke="none"/>
                    <circle cx="40" cy="30" r="2" fill="currentColor" stroke="none"/>
                    <path d="M29 38 C29 38 32 41 35 38"/>
                    <path d="M32 38 L32 42"/>
                    <path d="M20 26 L16 24 M20 28 L16 28 M20 30 L16 32"/>
                    <path d="M44 26 L48 24 M44 28 L48 28 M44 30 L48 32"/>
                  </svg>

                {%- when 'custom' -%}
                  {%- if block.settings.custom_svg != blank -%}
                    {{ block.settings.custom_svg }}
                  {%- else -%}
                    <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round"
                         aria-hidden="true" focusable="false">
                      <polygon points="32,6 39,24 58,24 44,35 49,53 32,42 15,53 20,35 6,24 25,24"/>
                    </svg>
                  {%- endif -%}

              {%- endcase -%}
            {%- endif -%}
          </div>

          <span class="gds-cat-name">{{ block.settings.label }}</span>
        </a>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Categorías GDS",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título de sección",
      "default": "Comprá por Categoría"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Encontrá todo lo que necesita tu mascota en un solo lugar"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categoría",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Nombre visible",
          "default": "Perros"
        },
        {
          "type": "text",
          "id": "collection_handle",
          "label": "Handle de la colección",
          "info": "Ej: perros → /collections/perros",
          "default": "perros"
        },
        {
          "type": "select",
          "id": "icon_type",
          "label": "Ícono",
          "options": [
            { "value": "perro",  "label": "Perro" },
            { "value": "gato",   "label": "Gato" },
            { "value": "custom", "label": "SVG personalizado" }
          ],
          "default": "perro"
        },
        {
          "type": "textarea",
          "id": "custom_svg",
          "label": "SVG personalizado",
          "info": "Pegar código SVG completo. Solo se usa si el ícono es 'SVG personalizado'."
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Categorías GDS",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "label": "Perros",
            "collection_handle": "perros",
            "icon_type": "perro"
          }
        },
        {
          "type": "category",
          "settings": {
            "label": "Gatos",
            "collection_handle": "gatos",
            "icon_type": "gato"
          }
        },
        {
          "type": "category",
          "settings": {
            "label": "Destacados",
            "collection_handle": "destacados",
            "icon_type": "custom"
          }
        }
      ]
    }
  ]
}
{% endschema %}
