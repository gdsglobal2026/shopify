{%- comment -%}
  LCP element: fetchpriority="high" + loading="eager" en la imagen.
  El <link preload> en body es procesado por el browser (válido en HTML5).
{%- endcomment -%}

<section class="gds-hero">
  <div class="gds-container">
    <div class="gds-hero-grid">

      <div class="gds-hero-content">
        <div class="gds-hero-badge">La tienda de accesorios para mascotas</div>

        <h1 class="gds-hero-title">
          {{ section.settings.heading }}<br>
          <span class="gds-text-blue">{{ section.settings.heading_line2 }}</span>
        </h1>

        {%- if section.settings.subheading != blank -%}
          <p class="gds-hero-sub">{{ section.settings.subheading }}</p>
        {%- endif -%}

        {%- if localization.country.iso_code == "AR" -%}
          <p class="gds-shipping-badge">🇦🇷 Envíos a todo Argentina</p>
        {%- else -%}
          <p class="gds-shipping-badge">🌎 Enviamos a {{ localization.country.name }}</p>
        {%- endif -%}

        <div class="gds-hero-btns">
          {%- if section.settings.button_label != blank -%}
            <a
              href="{{ section.settings.button_url | default: routes.all_products_collection_url }}"
              class="gds-btn gds-btn--gold"
            >
              {{- section.settings.button_label -}}
            </a>
          {%- endif -%}

          {%- if section.settings.button_secondary_label != blank -%}
            <a
              href="{{ section.settings.button_secondary_url | default: routes.collections_url }}"
              class="gds-btn gds-btn--outline-navy"
            >
              {{- section.settings.button_secondary_label -}}
            </a>
          {%- endif -%}
        </div>
      </div>

      <div class="gds-hero-visual">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image
             | image_url: width: 700
             | image_tag:
                 loading: "eager",
                 fetchpriority: "high",
                 preload: true,
                 width: 700,
                 height: 520,
                 class: "gds-hero-img",
                 alt: section.settings.heading }}
        {%- else -%}
          <div class="gds-hero-img-placeholder" aria-hidden="true">
            <span style="font-size:5rem;line-height:1;">🐾</span>
          </div>
        {%- endif -%}

        <div class="gds-hero-float-badge">
          <div class="gds-pct-num">+10K</div>
          <div class="gds-pct-lbl">mascotas felices</div>
        </div>
      </div>

    </div>
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Store",
  "name": "{{ shop.name | escape }}",
  "url": "{{ shop.url }}",
  "description": "{{ shop.description | strip_html | escape }}",
  "currenciesAccepted": "ARS, USD",
  "areaServed": "Worldwide"
}
</script>

{% stylesheet %}
  .gds-shipping-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 255, 255, .12);
    border: 1px solid rgba(255, 255, 255, .25);
    color: #fff;
    font-size: .82rem;
    font-weight: 600;
    padding: 6px 14px;
    border-radius: 999px;
    margin-bottom: 20px;
    letter-spacing: .2px;
  }

  .gds-hero-img {
    width: 100%;
    max-width: 520px;
    height: auto;
    border-radius: var(--gds-r-lg, 24px);
    object-fit: cover;
    display: block;
    margin: 0 auto;
    box-shadow: 0 16px 48px rgba(74,144,217,.2);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero GDS",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen principal"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título — línea 1",
      "default": "Todo lo que tu mascota"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Título — línea 2",
      "default": "necesita en un solo lugar"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Productos premium para perros y gatos. Envíos a toda América Latina y el mundo."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Botón principal — texto",
      "default": "Ver productos"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Botón principal — link"
    },
    {
      "type": "text",
      "id": "button_secondary_label",
      "label": "Botón secundario — texto",
      "default": "Ver ofertas"
    },
    {
      "type": "url",
      "id": "button_secondary_url",
      "label": "Botón secundario — link"
    }
  ],
  "presets": [
    {
      "name": "Hero GDS"
    }
  ]
}
{% endschema %}
